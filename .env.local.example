# Copy to .env.local and fill in values.

# eBay (optional — feed works with Chrono24 sample data without these)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_CA
# Optional: max listings for `npm run sync:ebay` (default 10000 prod / 50 local dev).
# EBAY_SEARCH_LIMIT=10000
# Optional: rate-limit sync pagination
# EBAY_PAGE_DELAY_MS=500            # prod default; local dev defaults to 10000
# EBAY_MIN_REQUEST_GAP_MS=8000      # min pause between any eBay HTTP call in dev
# EBAY_MAX_RETRIES=3                # local dev defaults to 1
# EBAY_RETRY_BASE_MS=2000           # local dev defaults to 60000
# EBAY_RATE_LIMIT_MODE=strict       # force conservative limits (auto when NODE_ENV != production)
# EBAY_RATE_LIMIT_MODE=production   # full sync limits from local machine
# Avoid in dev unless testing live eBay — capped at 25 listings per reload:
# EBAY_FORCE_REFRESH=1
# EBAY_LIVE_FETCH_LIMIT=25

# Etsy Open API v3 (optional — register at https://www.etsy.com/developers)
# Format: keystring:shared_secret from Your Apps → API key
ETSY_API_KEY=
# Or split:
# ETSY_KEYSTRING=
# ETSY_SHARED_SECRET=
# Optional: max listings for `npm run sync:etsy` (default 500)
# ETSY_SEARCH_LIMIT=500
# Optional: pipe-separated search queries (default: vintage timex watch)
# ETSY_SEARCH_QUERIES=vintage timex watch|timex marlin vintage
# ETSY_FORCE_REFRESH=1

# Chrono24 image enrichment (optional — bypasses Cloudflare for real listing photos)
# Start FlareSolverr: docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
# Then run: npm run enrich:chrono24
FLARESOLVERR_URL=http://localhost:8191/v1

# Supabase — required for cloud sync (hunts, dismissals, stars, etc.)
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Auth → URL configuration → add redirect URL: http://localhost:3000/auth/callback
# 4. Auth → Providers → enable Email (magic link)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Without Supabase vars, the app falls back to data/store/state.json locally.

# Optional: AI hunt search intent (classifies "womens", "marlin", etc. when rules are ambiguous)
# ANTHROPIC_API_KEY=
# ANTHROPIC_HUNT_INTENT_MODEL=claude-haiku-4-5-20251001
