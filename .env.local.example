# Copy to .env.local and fill in values.

# eBay (optional — feed works with Chrono24 sample data without these)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_CA
# Optional: max listings for `npm run sync:ebay` (default 2000). Page loads use disk cache instead.
# EBAY_SEARCH_LIMIT=2000

# Etsy Open API v3 (optional — register at https://www.etsy.com/developers)
# Format: keystring:shared_secret from Your Apps → API key
ETSY_API_KEY=
# Or split:
# ETSY_KEYSTRING=
# ETSY_SHARED_SECRET=
# Optional: max listings for `npm run sync:etsy` (default 500)
# ETSY_SEARCH_LIMIT=500
# Optional: pipe-separated search queries (default: vintage timex watch)
# ETSY_SEARCH_QUERIES=vintage timex watch|timex marlin vintage
# ETSY_FORCE_REFRESH=1

# Chrono24 image enrichment (optional — bypasses Cloudflare for real listing photos)
# Start FlareSolverr: docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
# Then run: npm run enrich:chrono24
FLARESOLVERR_URL=http://localhost:8191/v1

# Supabase — required for cloud sync (hunts, dismissals, stars, etc.)
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Auth → URL configuration → add redirect URL: http://localhost:3000/auth/callback
# 4. Auth → Providers → enable Email (magic link)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Without Supabase vars, the app falls back to data/store/state.json locally.
